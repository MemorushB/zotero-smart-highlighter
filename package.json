{
  "name": "zotero-pdf-highlighter",
  "version": "0.2.1",
  "description": "A Zotero 8 plugin for LLM-powered smart PDF highlighting.",
  "config": {
    "addonName": "Zotero Smart Highlighter",
    "addonID": "zotero-pdf-highlighter@memorushb.com",
    "addonRef": "zotero-pdf-highlighter",
    "addonInstance": "ZoteroPDFHighlighter",
    "prefsPrefix": "extensions.zotero-pdf-highlighter"
  },
  "main": "index.js",
  "scripts": {
    "postinstall": "node scripts/patch-zotero-plugin-scaffold-node25.mjs",
    "prebuild": "node scripts/patch-zotero-plugin-scaffold-node25.mjs",
    "start": "node scripts/serve-with-sidecar.mjs",
    "build": "node scripts/ensure-sidecar-build.mjs --mode build && zotero-plugin build && tsc --noEmit && node scripts/sync-scaffold-sidecar.mjs",
    "build:sidecar": "bash scripts/build-sidecar.sh",
    "build:legacy": "node build.js && tsc --noEmit",
    "release": "node scripts/ensure-sidecar-build.mjs --mode release && zotero-plugin release",
    "release:with-sidecar": "npm run release",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MemorushB/zotero-smart-highlighter.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/MemorushB/zotero-smart-highlighter/issues"
  },
  "homepage": "https://github.com/MemorushB/zotero-smart-highlighter#readme",
  "devDependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "adm-zip": "^0.5.16",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.3"
  }
}

# Copy this file to `.env` and set local paths.

# Zotero executable path.
# macOS example: /Applications/Zotero.app/Contents/MacOS/zotero
ZOTERO_PLUGIN_ZOTERO_BIN_PATH=/path/to/zotero

# Optional dev profile path.
# Create one with: /path/to/zotero -p
ZOTERO_PLUGIN_PROFILE_PATH=/path/to/zotero/profile

# Optional data dir. Leave empty to use default behavior.
ZOTERO_PLUGIN_DATA_DIR=
